--- COMPTE UTILISATEUR (modèle de base commun) ---

USER (compte patient, médecin, ou admin/secrétaire) :
  name, email, phone, password (bcrypt),
  role (patient/medecin/admin),
  avatar (base64 ou URL cloudinary),
  isVerified, verifyMethod (email/whatsapp),
  isActive, createdAt, deletedAt,
  refreshToken, lastLogin,

  // Préférences utilisateur (commun à tous les rôles) :
  preferences {
    language (fr/ar/en),
    timezone,
    currency,
    theme (light/dark/system),
    notifications {
      medical { email, push, inApp },      // résultats, prescriptions, rappels
      administrative { email, push, inApp }, // abonnements, paiements, RDV
      system { email, push, inApp },        // mises à jour, sécurité
      promotional { email, push, inApp }    // offres, newsletters
    },
    quietHours { start (HH:mm), end (HH:mm) },  // horaires non-dérangement
    digestFrequency (daily/weekly/none)     // fréquence emails résumé
  },

  // Sécurité :
  twoFactorEnabled (boolean),
  twoFactorSecret (string),
  failedLoginAttempts (number),
  lockUntil (Date),
